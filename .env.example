# ============================================================
# Auto Company — Environment Configuration
# ============================================================
# Copy this to .env and fill in your own values.
# .env is gitignored — never commit real keys.

# ── API Keys (multi-key rotation) ──
# Add up to 6 keys. The auto-loop rotates through them:
#   429 RPM  → wait 3min, retry same key
#   429 quota → mark exhausted, switch to next key (no wait)
#   401       → mark expired, switch to next key (no wait)
# Each key gets a 5-hour cooldown after exhaustion.
AC_API_KEY_1=sk-your-key-here
AC_API_KEY_2=
AC_API_KEY_3=
AC_API_KEY_4=
AC_API_KEY_5=
AC_API_KEY_6=

# ── API Endpoint (SenseNova or any Anthropic-compatible provider) ──
ANTHROPIC_BASE_URL=https://token.sensenova.cn
ANTHROPIC_MODEL=deepseek-v4-flash
MODEL=deepseek-v4-flash

# ── Key Account Labels (optional, for log readability) ──
# Set a human-readable name for each key to avoid exposing
# the raw key prefix in logs.
AC_API_KEY_1_ACCOUNT=my-account-1
AC_API_KEY_2_ACCOUNT=
AC_API_KEY_3_ACCOUNT=
AC_API_KEY_4_ACCOUNT=
AC_API_KEY_5_ACCOUNT=
AC_API_KEY_6_ACCOUNT=

# ── Telegram Bot (optional) ──
# Create a bot at @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=
